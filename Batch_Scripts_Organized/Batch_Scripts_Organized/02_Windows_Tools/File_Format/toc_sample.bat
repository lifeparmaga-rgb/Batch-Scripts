@echo off

set toc_sample="<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>oop_gpt_toc_final_v Content with TOC</title><style>body{direction:rtl}pre code{direction:ltr;text-align:left}*,::before,:after,html{scroll-behavior:smooth}body{display:flex;justify-content:flex-start;font-family:Arial,sans-serif;background-color:#f4f4f4;padding:20px;margin:0}#main-container{display:flex;justify-content:space-between;width:100%;margin-top:20px}#toc-container{width:auto;height:auto;min-width:min-content;max-width:max-content;background-color:rgba(255,255,255,.9);padding:15px;border-radius:8px;box-shadow:0 0 10px rgba(0,0,0,.2);max-height:90vh;overflow-y:auto;margin-right:20px;display:block;position:sticky;top:20px;align-self:flex-start}#toc-container ul{list-style:none;padding:0;margin:0}#toc-container li{margin-bottom:10px;border-bottom:2px solid #e0e0e0}#toc-container a{text-decoration:none;color:#007bff;font-size:14px;display:block;padding:5px;cursor:pointer}#toc-container a:hover{background-color:#f0f0f0}#content-container{flex-grow:1;padding:20px;background-color:#fff;border-radius:8px;box-shadow:0 0 10px rgba(0,0,0,.1)}h1,h2,h3,h4,h5,h6{font-family:Arial,sans-serif;color:#333}#toggle-toc{position:fixed;top:20px;right:-1px;background-color:gray;color:#fff;padding:10px;border:none;border-radius:5px;cursor:pointer;z-index:1000}#toggle-toc:hover{background-color:gray}</style></head><body><button id="toggle-toc">+</button><div id="main-container"><div id="toc-container"></div><div id="content-container"></div></div><script>function isArabic(t){return/[\u0600-\u06FF]/.test(t)}function applyDirectionBasedOnLanguage(t=document){t.querySelectorAll("p, li, h1, h2, h3, h4, h5, h6").forEach(t=>{const e=t.textContent.trim();if(e)isArabic(e)?(t.style.direction="rtl",t.style.textAlign="right"):(t.style.direction="ltr",t.style.textAlign="left")})}function generateTOC(){document.querySelectorAll("h1, h2, h3, h4, h5, h6").forEach((t,e)=>{const o=document.createElement("li"),n=document.createElement("a");t.id||(t.id="heading-"+e),n.href=`#${t.id}`,n.textContent=t.textContent,o.appendChild(n),document.getElementById("toc-container").appendChild(o)})}document.getElementById("toggle-toc").addEventListener("click",function(){const t=document.getElementById("toc-container");t.style.display="none"===t.style.display?"block":"none"}),document.addEventListener("DOMContentLoaded",function(){applyDirectionBasedOnLanguage(),generateTOC()});const toggleBtn=document.getElementById("toggle-toc"),tocContent=document.getElementById("toc-container");let isVisible=!0;toggleBtn.addEventListener("click",()=>{isVisible=!isVisible,tocContent.style.display=isVisible?"block":"none",toggleBtn.textContent=isVisible?"-":"+"});</script></body></html>"

echo %toc_sample% | clip